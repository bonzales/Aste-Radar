# --- API Anthropic (estrazione perizia -> JSON, CLAUDE.md §7) ---
ANTHROPIC_API_KEY=

# --- Opzionale: disattiva telemetria Superpowers (CLAUDE.md §9.1) ---
# SUPERPOWERS_DISABLE_TELEMETRY=1
